{
  "name": "@dozyio/pcp",
  "version": "0.0.0",
  "description": "PCP (RFC 6887) port mapping for Node.js",
  "license": "Apache-2.0 OR MIT",
  "homepage": "https://github.com/dozyio/js-pcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dozyio/js-pcp.git"
  },
  "bugs": {
    "url": "https://github.com/dozyio/js-pcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "libp2p",
    "nat",
    "pcp",
    "rfc6887",
    "port-mapping"
  ],
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "files": [
    "src",
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits",
          "releaseRules": [
            {
              "breaking": true,
              "release": "major"
            },
            {
              "revert": true,
              "release": "patch"
            },
            {
              "type": "feat",
              "release": "minor"
            },
            {
              "type": "fix",
              "release": "patch"
            },
            {
              "type": "docs",
              "release": "patch"
            },
            {
              "type": "test",
              "release": "patch"
            },
            {
              "type": "deps",
              "release": "patch"
            },
            {
              "scope": "no-release",
              "release": false
            }
          ]
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits",
          "presetConfig": {
            "types": [
              {
                "type": "feat",
                "section": "Features"
              },
              {
                "type": "fix",
                "section": "Bug Fixes"
              },
              {
                "type": "chore",
                "section": "Trivial Changes"
              },
              {
                "type": "docs",
                "section": "Documentation"
              },
              {
                "type": "deps",
                "section": "Dependencies"
              },
              {
                "type": "test",
                "section": "Tests"
              }
            ]
          }
        }
      ],
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ]
        }
      ]
    ]
  },
  "scripts": {
    "clean": "aegir clean",
    "lint": "aegir lint",
    "dep-check": "aegir dep-check",
    "doc-check": "aegir doc-check",
    "build": "aegir build --no-bundle",
    "docs": "aegir docs",
    "release": "aegir release",
    "test": "aegir test -t node",
    "test:node": "aegir test -t node"
  },
  "dependencies": {
    "@chainsafe/is-ip": "^2.1.0",
    "@libp2p/logger": "^5.0.1",
    "abort-error": "^1.0.0",
    "err-code": "^3.0.1",
    "netmask": "^2.0.2",
    "p-defer": "^4.0.0",
    "race-signal": "^1.1.0"
  },
  "devDependencies": {
    "@types/netmask": "^2.0.5",
    "aegir": "^47.0.17",
    "chai": "^4.5.0"
  }
}
